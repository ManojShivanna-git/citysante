{
  "expo": {
    "name": "Isanthe Shop",
    "slug": "isanthe-shop-owner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.isanthe.shop",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.isanthe.shop",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "8f9fe4bc-53e7-4e8a-8adb-1339e81f0103"
      }
    }
  }
}
