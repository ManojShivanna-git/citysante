# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=citysante
DB_USER=apple
DB_PASSWORD=

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SMS (Fast2SMS) ───────────────────────────────────
FAST2SMS_API_KEY=

# ─── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase ─────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Google Maps ──────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── App ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Business Rules ───────────────────────────────────
COMMISSION_PER_ORDER=2
PAYMENT_THRESHOLD=2000
FAST_GROWTH_THRESHOLD=5000
OTP_EXPIRY_MINUTES=5
